@model Rol
@{
    ViewData["Title"] = "Nuevo rol";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-4"><i class="bi bi-plus-circle me-2"></i>Nuevo rol</h1>

        @* Error de validación o de nombre duplicado devuelto por la capa de Negocio. *@
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="CrearRol" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="Nombre" class="form-label">Nombre del rol</label>
                        <input asp-for="Nombre" class="form-control" maxlength="50" autofocus
                               placeholder="Ej.: Supervisor de Taller" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

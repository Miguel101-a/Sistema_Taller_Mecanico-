@model List<Rol>
@{
    ViewData["Title"] = "Roles y Permisos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-shield-lock me-2"></i>Roles y Permisos</h1>
        <p class="text-muted mb-0">Gestione los roles del sistema y los permisos asignados a cada uno.</p>
    </div>
    <a asp-action="CrearRol" class="btn btn-sgtmj-primario">
        <i class="bi bi-plus-lg me-1"></i>Nuevo rol
    </a>
</div>

@* Mensajes de éxito o error provenientes de las acciones del controlador. *@
@if (TempData["Exito"] != null)
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i>@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
}

<div class="card sgtmj-card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rol in Model)
                {
                    bool activo = rol.Estado.Trim().ToUpperInvariant() == "ACTIVO";
                    bool esAdmin = rol.IdRol == TallerJuan.Negocio.CN_Seguridad.IdRolAdministrador;
                    <tr class="@(activo ? "" : "text-muted opacity-75")">
                        <td>
                            <span class="fw-semibold">@rol.Nombre</span>
                            @if (esAdmin)
                            {
                                <span class="badge bg-secondary ms-2">Sistema</span>
                            }
                        </td>
                        <td>
                            @if (activo)
                            {
                                <span class="badge text-bg-success">ACTIVO</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">INACTIVO</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Permisos" asp-route-idRol="@rol.IdRol" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-key me-1"></i>Gestionar permisos
                            </a>
                            <a asp-action="EditarRol" asp-route-idRol="@rol.IdRol" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil me-1"></i>Editar
                            </a>
                            @* Cambiar estado: POST con token antifalsificación. El Administrador no se puede desactivar. *@
                            <form asp-action="CambiarEstado" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idRol" value="@rol.IdRol" />
                                @if (esAdmin && activo)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled
                                            title="El rol Administrador no se puede desactivar.">
                                        <i class="bi bi-lock me-1"></i>Desactivar
                                    </button>
                                }
                                else if (activo)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-toggle-off me-1"></i>Desactivar
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-toggle-on me-1"></i>Activar
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model PermisosRolViewModel
@{
    ViewData["Title"] = "Gestionar permisos";
    // Se agrupan los permisos por MODULO para mostrarlos en tarjetas separadas.
    var porModulo = Model.Permisos
        .GroupBy(p => string.IsNullOrWhiteSpace(p.Modulo) ? "General" : p.Modulo)
        .OrderBy(g => g.Key);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-key me-2"></i>Permisos del rol</h1>
        <p class="text-muted mb-0">
            Rol: <span class="fw-semibold text-dark">@Model.NombreRol</span>.
            Marque los permisos que tendrá este rol y guarde los cambios.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<form asp-action="GuardarPermisos" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="idRol" value="@Model.IdRol" />

    <div class="row g-3">
        @foreach (var grupo in porModulo)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card sgtmj-card h-100 shadow-sm border-0">
                    <div class="card-header bg-transparent fw-semibold">
                        <i class="bi bi-folder2-open me-1 text-muted"></i>@grupo.Key
                    </div>
                    <div class="card-body">
                        @foreach (var permiso in grupo.OrderBy(p => p.Descripcion))
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox"
                                       name="permisosSeleccionados" value="@permiso.IdPermiso"
                                       id="perm_@permiso.IdPermiso" @(permiso.Asignado ? "checked" : "") />
                                <label class="form-check-label" for="perm_@permiso.IdPermiso">
                                    @permiso.Descripcion
                                    <span class="d-block text-muted small">@permiso.Clave</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-sgtmj-primario">
            <i class="bi bi-save me-1"></i>Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="sgtmj-login-fondo">
    <div class="sgtmj-login-card">
        <div class="text-center mb-4">
            <img src="~/img/logo.png" alt="Logo Taller Mecánico JUAN" class="sgtmj-login-logo" />
            <h1 class="h5 fw-semibold mb-0">Taller Mecánico Automotriz JUAN</h1>
            <p class="text-muted small mb-0">Sistema de Gestión (SGTMJ)</p>
        </div>

        @* Zona para el mensaje de error de credenciales. *@
        @if (!string.IsNullOrEmpty(Model.MensajeError))
        {
            <div class="alert alert-danger py-2" role="alert" style="color: var(--sgtmj-error);">
                <i class="bi bi-exclamation-triangle me-1"></i>@Model.MensajeError
            </div>
        }

        <form asp-controller="Acceso" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Usuario" class="form-label"></label>
                <input asp-for="Usuario" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="Usuario" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Clave" class="form-label"></label>
                @* input-group con el botón "ojo" para mostrar/ocultar la contraseña. *@
                <div class="input-group">
                    <input asp-for="Clave" class="form-control" autocomplete="current-password" id="campoClave" />
                    <button class="btn btn-outline-secondary" type="button" id="botonOjo"
                            aria-label="Mostrar u ocultar contraseña" aria-pressed="false">
                        <i class="bi bi-eye" id="iconoOjo"></i>
                    </button>
                </div>
                <span asp-validation-for="Clave" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-sgtmj-primario">Iniciar sesión</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Alterna la visibilidad de la contraseña sin librerías externas (vanilla JS).
        (function () {
            var boton = document.getElementById("botonOjo");
            var campo = document.getElementById("campoClave");
            var icono = document.getElementById("iconoOjo");
            if (!boton || !campo || !icono) return;

            boton.addEventListener("click", function () {
                var visible = campo.getAttribute("type") === "text";
                // Si estaba visible se oculta, y viceversa.
                campo.setAttribute("type", visible ? "password" : "text");
                icono.classList.toggle("bi-eye", visible);
                icono.classList.toggle("bi-eye-slash", !visible);
                boton.setAttribute("aria-pressed", visible ? "false" : "true");
            });
        })();
    </script>
}

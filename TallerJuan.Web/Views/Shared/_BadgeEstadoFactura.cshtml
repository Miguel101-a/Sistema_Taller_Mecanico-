@model string
@{
    // Mapea el estado de la factura a su clase CSS de color. Reutilizable en listado y detalle.
    string estado = (Model ?? string.Empty).Trim().ToUpperInvariant();
    string clase = estado switch
    {
        "BORRADOR" => "sgtmj-factura-borrador",
        "EMITIDA" => "sgtmj-factura-emitida",
        "ANULADA" => "sgtmj-factura-anulada",
        _ => "sgtmj-estado-inactivo"
    };
}
<span class="sgtmj-badge @clase">@(string.IsNullOrWhiteSpace(estado) ? "—" : estado)</span>

@model string
@{
    // Mapea el estado de la orden a su clase CSS de color. Reutilizable en listado y detalle.
    string estado = (Model ?? string.Empty).Trim().ToUpperInvariant();
    string clase = estado switch
    {
        "RECIBIDO" => "sgtmj-orden-recibido",
        "EN DIAGNOSTICO" => "sgtmj-orden-en-diagnostico",
        "EN REPARACION" => "sgtmj-orden-en-reparacion",
        "FINALIZADO" => "sgtmj-orden-finalizado",
        "ENTREGADO" => "sgtmj-orden-entregado",
        _ => "sgtmj-estado-inactivo"
    };
}
<span class="sgtmj-badge @clase">@(string.IsNullOrWhiteSpace(estado) ? "—" : estado)</span>

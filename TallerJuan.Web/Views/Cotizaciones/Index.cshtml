@model List<Cotizacion>
@{
    ViewData["Title"] = "Cotizaciones";
    var sesion = Context.Session;
    bool puedeEditar = SesionWeb.TienePermiso(sesion, "COTIZACIONES_EDITAR");
    var cultura = new System.Globalization.CultureInfo("es-BO");
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-file-earmark-text me-2"></i>Cotizaciones</h1>
        <p class="text-muted mb-0">Cotizaciones emitidas, su estado y total con IVA 13%.</p>
    </div>
    @if (puedeEditar)
    {
        <a asp-action="Crear" class="btn btn-sgtmj-primario">
            <i class="bi bi-plus-lg me-1"></i>Nueva cotización
        </a>
    }
</div>

<div class="card sgtmj-card shadow-sm border-0">
    <div class="sgtmj-tabla-herramientas">
        <input type="search" class="form-control sgtmj-buscador" placeholder="Buscar cotización…"
               data-tabla="tablaCotizaciones" data-contador="contadorCotizaciones" autocomplete="off" />
        <span class="sgtmj-contador" id="contadorCotizaciones"></span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="tablaCotizaciones">
            <thead class="table-light">
                <tr>
                    <th>N°</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Vehículo</th>
                    <th class="text-end">Total</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr data-sin-filtro>
                        <td colspan="7" class="text-center text-muted py-4">No hay cotizaciones registradas.</td>
                    </tr>
                }
                @foreach (var q in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@q.NumeroCotizacion</td>
                        <td>@q.FechaEmision.ToString("dd/MM/yyyy")</td>
                        <td>@q.ClienteNombre</td>
                        <td>@q.VehiculoPlaca — @q.VehiculoDescripcion</td>
                        <td class="text-end fw-semibold">Bs @q.Total.ToString("N2", cultura)</td>
                        <td><partial name="_BadgeEstadoCotizacion" model="@q.Estado" /></td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-numeroCotizacion="@q.NumeroCotizacion" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Ver detalle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model CotizacionCrearViewModel
@{
    ViewData["Title"] = "Nueva cotización";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <h1 class="h3 mb-4"><i class="bi bi-file-earmark-text me-2"></i>Nueva cotización</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClienteCedula" class="form-label">Cliente <span class="text-danger">*</span></label>
                            <select asp-for="ClienteCedula" class="form-select" id="selCliente" required>
                                <option value="">— Seleccione un cliente —</option>
                                @foreach (var c in Model.Clientes)
                                {
                                    <option value="@c.Cedula">@c.Nombre (@c.Cedula)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VehiculoPlaca" class="form-label">Vehículo <span class="text-danger">*</span></label>
                            <select asp-for="VehiculoPlaca" class="form-select" id="selVehiculo" required disabled>
                                <option value="">— Seleccione primero un cliente —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ValidezDias" class="form-label">Validez (días) <span class="text-danger">*</span></label>
                            <input asp-for="ValidezDias" type="number" min="1" max="90" class="form-control" required />
                            <div class="form-text">Entre 1 y 90 días.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Crear y agregar líneas
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Carga en cascada de los vehículos del cliente elegido (mismo mecanismo que en Órdenes).
        (function () {
            var selCliente = document.getElementById("selCliente");
            var selVehiculo = document.getElementById("selVehiculo");
            var urlBase = "@Url.Action("VehiculosPorCliente")";

            selCliente.addEventListener("change", function () {
                var cedula = selCliente.value;
                selVehiculo.innerHTML = '<option value="">Cargando…</option>';
                selVehiculo.disabled = true;

                if (!cedula) {
                    selVehiculo.innerHTML = '<option value="">— Seleccione primero un cliente —</option>';
                    return;
                }

                fetch(urlBase + "?cedula=" + encodeURIComponent(cedula))
                    .then(function (r) { return r.json(); })
                    .then(function (vehiculos) {
                        if (!vehiculos || vehiculos.length === 0) {
                            selVehiculo.innerHTML = '<option value="">El cliente no tiene vehículos activos</option>';
                            selVehiculo.disabled = true;
                            return;
                        }
                        var html = '<option value="">— Seleccione un vehículo —</option>';
                        vehiculos.forEach(function (v) {
                            html += '<option value="' + v.placa + '">' + v.descripcion + '</option>';
                        });
                        selVehiculo.innerHTML = html;
                        selVehiculo.disabled = false;
                    })
                    .catch(function () {
                        selVehiculo.innerHTML = '<option value="">Error al cargar los vehículos</option>';
                        selVehiculo.disabled = true;
                    });
            });
        })();
    </script>
}

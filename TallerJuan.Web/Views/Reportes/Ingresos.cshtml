@model ReporteFiltroViewModel
@{
    ViewData["Title"] = "Ingresos por período";
    var cultura = new System.Globalization.CultureInfo("es-BO");
    var resultados = ViewBag.Resultados as List<ReporteIngresoPeriodo> ?? new List<ReporteIngresoPeriodo>();
    decimal maxTotal = resultados.Count > 0 ? resultados.Max(r => r.Total) : 0m;
    decimal totalPeriodo = resultados.Sum(r => r.Total);
    int totalFacturas = resultados.Sum(r => r.CantidadFacturas);
}

<div class="sgtmj-encabezado sgtmj-no-print">
    <div>
        <h1><i class="bi bi-cash-coin me-2"></i>Ingresos por período</h1>
        <p class="text-muted mb-0">RF-37 · Total facturado (facturas EMITIDAS), agrupado por día, mes o año.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card sgtmj-card shadow-sm border-0 mb-4 sgtmj-no-print">
    <div class="card-body">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }
        <form asp-action="Ingresos" method="get" class="row g-3 align-items-end">
            <div class="col-sm-3">
                <label class="form-label">Desde</label>
                <input type="date" name="fechaInicio" class="form-control" value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-sm-3">
                <label class="form-label">Hasta</label>
                <input type="date" name="fechaFin" class="form-control" value="@Model.FechaFin.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-sm-3">
                <label class="form-label">Agrupar por</label>
                <select name="agrupacion" class="form-select">
                    <option value="DIA" selected="@(Model.Agrupacion == "DIA")">Día</option>
                    <option value="MES" selected="@(Model.Agrupacion == "MES")">Mes</option>
                    <option value="ANIO" selected="@(Model.Agrupacion == "ANIO")">Año</option>
                </select>
            </div>
            <div class="col-sm-3 d-flex gap-2">
                <button type="submit" class="btn btn-sgtmj-primario"><i class="bi bi-search me-1"></i>Generar</button>
                <button type="button" class="btn btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-1"></i>Imprimir</button>
            </div>
        </form>
    </div>
</div>

<div class="sgtmj-print-titulo d-none">
    <h2 class="h4 mb-1">Ingresos por período (RF-37)</h2>
    <p class="text-muted mb-3">Del @Model.FechaInicio.ToString("dd/MM/yyyy") al @Model.FechaFin.ToString("dd/MM/yyyy") · agrupado por @Model.Agrupacion</p>
</div>

@if (resultados.Count == 0)
{
    <div class="alert sgtmj-stock-bajo border-0 d-flex align-items-center">
        <i class="bi bi-info-circle me-2"></i>No se encontraron datos en el período seleccionado.
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card sgtmj-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Total facturado del período</div>
                    <div class="sgtmj-reporte-total">Bs @totalPeriodo.ToString("N2", cultura)</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card sgtmj-card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Facturas emitidas</div>
                    <div class="sgtmj-reporte-total">@totalFacturas</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card sgtmj-card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Período</th>
                        <th class="text-end">Facturas</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">IVA</th>
                        <th class="text-end">Total</th>
                        <th style="width:30%">Comparativa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in resultados)
                    {
                        int ancho = maxTotal > 0 ? (int)Math.Round(r.Total / maxTotal * 100) : 0;
                        <tr>
                            <td class="fw-semibold">@r.Periodo</td>
                            <td class="text-end">@r.CantidadFacturas</td>
                            <td class="text-end">Bs @r.Subtotal.ToString("N2", cultura)</td>
                            <td class="text-end">Bs @r.Iva.ToString("N2", cultura)</td>
                            <td class="text-end fw-semibold">Bs @r.Total.ToString("N2", cultura)</td>
                            <td><div class="sgtmj-barra"><span style="width:@ancho%"></span></div></td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td>TOTAL</td>
                        <td class="text-end">@totalFacturas</td>
                        <td colspan="2"></td>
                        <td class="text-end">Bs @totalPeriodo.ToString("N2", cultura)</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

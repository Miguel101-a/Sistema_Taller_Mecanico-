@model List<Vehiculo>
@{
    ViewData["Title"] = "Vehículos";
    var sesion = Context.Session;
    bool puedeEditar = SesionWeb.TienePermiso(sesion, "VEHICULOS_EDITAR");
    bool puedeEliminar = SesionWeb.TienePermiso(sesion, "VEHICULOS_ELIMINAR");
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-car-front me-2"></i>Vehículos</h1>
        <p class="text-muted mb-0">Vehículos registrados y su cliente propietario.</p>
    </div>
    @if (puedeEditar)
    {
        <a asp-action="Crear" class="btn btn-sgtmj-primario">
            <i class="bi bi-plus-lg me-1"></i>Nuevo vehículo
        </a>
    }
</div>

<div class="card sgtmj-card shadow-sm border-0">
    <div class="sgtmj-tabla-herramientas">
        <input type="search" class="form-control sgtmj-buscador" placeholder="Buscar vehículo…"
               data-tabla="tablaVehiculos" data-contador="contadorVehiculos" autocomplete="off" />
        <span class="sgtmj-contador" id="contadorVehiculos"></span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="tablaVehiculos">
            <thead class="table-light">
                <tr>
                    <th>Placa</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Año</th>
                    <th>Cliente</th>
                    <th>Estado</th>
                    @if (puedeEditar || puedeEliminar)
                    {
                        <th class="text-end">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr data-sin-filtro>
                        <td colspan="7" class="text-center text-muted py-4">No hay vehículos registrados.</td>
                    </tr>
                }
                @foreach (var v in Model)
                {
                    bool activo = v.Estado.Trim().ToUpperInvariant() == "ACTIVO";
                    <tr class="@(activo ? "" : "text-muted opacity-75")">
                        <td class="fw-semibold">@v.Placa</td>
                        <td>@v.Marca</td>
                        <td>@v.Modelo</td>
                        <td>@(v.Anio?.ToString() ?? "—")</td>
                        <td>@v.ClienteNombre</td>
                        <td>
                            <span class="sgtmj-badge @(activo ? "sgtmj-estado-activo" : "sgtmj-estado-inactivo")">
                                @(activo ? "ACTIVO" : "INACTIVO")
                            </span>
                        </td>
                        @if (puedeEditar || puedeEliminar)
                        {
                            <td class="text-end">
                                @if (puedeEditar)
                                {
                                    <a asp-action="Editar" asp-route-id="@v.Placa" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                }
                                @if (puedeEliminar && activo)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning js-confirmar"
                                            data-accion="@Url.Action("Eliminar")" data-campo="id" data-valor="@v.Placa"
                                            data-mensaje="¿Está seguro de desactivar el vehículo @v.Placa?">
                                        <i class="bi bi-toggle-off me-1"></i>Desactivar
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

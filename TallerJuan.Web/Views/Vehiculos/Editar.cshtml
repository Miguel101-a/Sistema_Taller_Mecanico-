@model Vehiculo
@{
    ViewData["Title"] = "Editar vehículo";
    var clientes = ViewBag.Clientes as List<Cliente> ?? new List<Cliente>();
    int anioMax = DateTime.Now.Year + 1;
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <h1 class="h3 mb-4"><i class="bi bi-pencil-square me-2"></i>Editar vehículo</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    @* La placa es la PK: se muestra pero no se edita; se envía oculta. *@
                    <input type="hidden" asp-for="Placa" />
                    <input type="hidden" asp-for="Estado" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Placa</label>
                            <input class="form-control" value="@Model.Placa" disabled readonly />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Marca" class="form-label">Marca <span class="text-danger">*</span></label>
                            <input asp-for="Marca" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Modelo" class="form-label">Modelo <span class="text-danger">*</span></label>
                            <input asp-for="Modelo" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Anio" class="form-label">Año</label>
                            <input asp-for="Anio" type="number" class="form-control" min="1950" max="@anioMax" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Color" class="form-label">Color</label>
                            <input asp-for="Color" class="form-control" maxlength="30" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Kilometraje" class="form-label">Kilometraje</label>
                            <input asp-for="Kilometraje" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NumeroChasis" class="form-label">N° de chasis</label>
                            <input asp-for="NumeroChasis" class="form-control" maxlength="50" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NumeroMotor" class="form-label">N° de motor</label>
                            <input asp-for="NumeroMotor" class="form-control" maxlength="50" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TipoCombustible" class="form-label">Tipo de combustible</label>
                            <select asp-for="TipoCombustible" class="form-select">
                                <option value="">— Seleccione —</option>
                                <option value="Gasolina">Gasolina</option>
                                <option value="Diésel">Diésel</option>
                                <option value="Gas (GNV)">Gas (GNV)</option>
                                <option value="Eléctrico">Eléctrico</option>
                                <option value="Híbrido">Híbrido</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ClienteCedula" class="form-label">Cliente propietario <span class="text-danger">*</span></label>
                            <select asp-for="ClienteCedula" class="form-select" required>
                                <option value="">— Seleccione un cliente —</option>
                                @foreach (var c in clientes)
                                {
                                    <option value="@c.Cedula">@c.Nombre (@c.Cedula)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Guardar cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

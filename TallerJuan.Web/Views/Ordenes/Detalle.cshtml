@model OrdenTrabajo
@{
    ViewData["Title"] = $"Orden de trabajo N° {Model.NumeroOrden}";
    var sesion = Context.Session;
    bool puedeEditar = SesionWeb.TienePermiso(sesion, "ORDENES_EDITAR");
    bool puedeCerrar = SesionWeb.TienePermiso(sesion, "ORDENES_CERRAR");
    bool puedeDiagnosticar = SesionWeb.TienePermiso(sesion, "DIAGNOSTICO_EDITAR");

    var diagnosticos = ViewBag.Diagnosticos as List<Diagnostico> ?? new List<Diagnostico>();
    var cultura = new System.Globalization.CultureInfo("es-BO");

    string estado = Model.Estado.Trim().ToUpperInvariant();
    bool entregada = estado == "ENTREGADO";

    // Estados a los que se puede avanzar desde el estado actual.
    // Los marcados con cierre (FINALIZADO/ENTREGADO) requieren el permiso ORDENES_CERRAR.
    var siguientes = estado switch
    {
        "RECIBIDO" => new[] { "EN DIAGNOSTICO", "EN REPARACION" },
        "EN DIAGNOSTICO" => new[] { "EN REPARACION", "FINALIZADO" },
        "EN REPARACION" => new[] { "FINALIZADO" },
        "FINALIZADO" => new[] { "ENTREGADO" },
        _ => System.Array.Empty<string>()
    };
    var estadosCierre = new[] { "FINALIZADO", "ENTREGADO" };
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-wrench-adjustable me-2"></i>Orden de trabajo N° @Model.NumeroOrden</h1>
        <p class="text-muted mb-0">Detalle de la orden, diagnósticos y cambios de estado.</p>
    </div>
    <div class="d-flex gap-2">
        @if (puedeEditar && !entregada)
        {
            <a asp-action="Editar" asp-route-id="@Model.NumeroOrden" class="btn btn-outline-secondary">
                <i class="bi bi-pencil me-1"></i>Editar
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="row g-4">
    @* ---------------- Columna izquierda: datos de la orden ---------------- *@
    <div class="col-lg-5">
        <div class="card sgtmj-card shadow-sm border-0 mb-4">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-info-circle me-1 text-muted"></i>Datos de la orden</span>
                <partial name="_BadgeEstadoOrden" model="@Model.Estado" />
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Cliente</dt>
                    <dd class="col-7">@Model.ClienteNombre <span class="text-muted">(@Model.ClienteCedula)</span></dd>

                    <dt class="col-5 text-muted">Vehículo</dt>
                    <dd class="col-7">@Model.VehiculoPlaca — @Model.VehiculoDescripcion</dd>

                    <dt class="col-5 text-muted">Mecánico</dt>
                    <dd class="col-7">@Model.EmpleadoNombre</dd>

                    <dt class="col-5 text-muted">Kilometraje</dt>
                    <dd class="col-7">@(Model.KilometrajeIngreso?.ToString("N0", cultura) ?? "—")</dd>

                    <dt class="col-5 text-muted">Fecha ingreso</dt>
                    <dd class="col-7">@Model.FechaIngreso.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-5 text-muted">Fecha entrega</dt>
                    <dd class="col-7">@(Model.FechaEntrega?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>

                    <dt class="col-5 text-muted">Motivo</dt>
                    <dd class="col-7">@(string.IsNullOrWhiteSpace(Model.MotivoVisita) ? "—" : Model.MotivoVisita)</dd>

                    <dt class="col-5 text-muted">Problema</dt>
                    <dd class="col-7">@(string.IsNullOrWhiteSpace(Model.DescripcionProblema) ? "—" : Model.DescripcionProblema)</dd>
                </dl>
            </div>
        </div>

        @* ---------------- Cambios de estado ---------------- *@
        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-arrow-repeat me-1 text-muted"></i>Cambiar estado
            </div>
            <div class="card-body">
                @if (entregada)
                {
                    <p class="text-muted mb-0"><i class="bi bi-lock me-1"></i>La orden fue entregada; no admite más cambios.</p>
                }
                else if (siguientes.Length == 0)
                {
                    <p class="text-muted mb-0">No hay transiciones disponibles.</p>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var sig in siguientes)
                        {
                            bool requiereCierre = estadosCierre.Contains(sig);
                            bool autorizado = requiereCierre ? puedeCerrar : puedeEditar;
                            if (autorizado)
                            {
                                <form asp-action="CambiarEstado" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.NumeroOrden" />
                                    <input type="hidden" name="estado" value="@sig" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-arrow-right-circle me-1"></i>@sig
                                    </button>
                                </form>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ---------------- Columna derecha: diagnósticos ---------------- *@
    <div class="col-lg-7">
        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-clipboard2-pulse me-1 text-muted"></i>Diagnósticos (@diagnosticos.Count)
            </div>
            <div class="card-body">
                @if (diagnosticos.Count == 0)
                {
                    <p class="text-muted">Aún no se han registrado diagnósticos para esta orden.</p>
                }
                else
                {
                    foreach (var d in diagnosticos)
                    {
                        <div class="sgtmj-diagnostico">
                            <div class="d-flex justify-content-between">
                                <span class="sgtmj-diagnostico-fecha">
                                    <i class="bi bi-calendar3 me-1"></i>@d.Fecha.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                <span class="small text-muted">
                                    @if (d.TiempoEstimado.HasValue)
                                    {
                                        <span class="me-3"><i class="bi bi-clock me-1"></i>@d.TiempoEstimado.Value.ToString("0.##", cultura) h</span>
                                    }
                                    @if (d.CostoEstimado.HasValue)
                                    {
                                        <span><i class="bi bi-cash me-1"></i>Bs @d.CostoEstimado.Value.ToString("N2", cultura)</span>
                                    }
                                </span>
                            </div>
                            <div class="mt-1">@d.Descripcion</div>
                        </div>
                    }
                }

                @* ---------------- Formulario para agregar diagnóstico ---------------- *@
                @if (puedeDiagnosticar && !entregada)
                {
                    <hr />
                    <h6 class="text-muted mb-3">Agregar diagnóstico</h6>
                    <form asp-action="AgregarDiagnostico" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="OrdenTrabajoNumeroOrden" value="@Model.NumeroOrden" />
                        <div class="mb-3">
                            <label class="form-label">Descripción <span class="text-danger">*</span></label>
                            <textarea name="Descripcion" class="form-control" maxlength="1000" rows="2" required></textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Tiempo estimado (horas)</label>
                                <input name="TiempoEstimado" type="number" step="0.01" min="0" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Costo estimado (Bs)</label>
                                <input name="CostoEstimado" type="number" step="0.01" min="0" class="form-control" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-sgtmj-primario mt-3">
                            <i class="bi bi-plus-lg me-1"></i>Agregar diagnóstico
                        </button>
                    </form>
                }
                else if (entregada)
                {
                    <hr />
                    <p class="text-muted mb-0"><i class="bi bi-lock me-1"></i>La orden fue entregada; no se pueden agregar diagnósticos.</p>
                }
            </div>
        </div>
    </div>
</div>

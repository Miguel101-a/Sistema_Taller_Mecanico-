@model OrdenCrearViewModel
@{
    ViewData["Title"] = "Nueva orden de trabajo";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-9">
        <h1 class="h3 mb-4"><i class="bi bi-wrench-adjustable me-2"></i>Nueva orden de trabajo</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClienteCedula" class="form-label">Cliente <span class="text-danger">*</span></label>
                            <select asp-for="ClienteCedula" class="form-select" id="selCliente" required>
                                <option value="">— Seleccione un cliente —</option>
                                @foreach (var c in Model.Clientes)
                                {
                                    <option value="@c.Cedula">@c.Nombre (@c.Cedula)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Orden.VehiculoPlaca" class="form-label">Vehículo <span class="text-danger">*</span></label>
                            <select asp-for="Orden.VehiculoPlaca" class="form-select" id="selVehiculo" required disabled>
                                <option value="">— Seleccione primero un cliente —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Orden.EmpleadoCedula" class="form-label">Mecánico asignado <span class="text-danger">*</span></label>
                            <select asp-for="Orden.EmpleadoCedula" class="form-select" required>
                                <option value="">— Seleccione un mecánico —</option>
                                @foreach (var m in Model.Mecanicos)
                                {
                                    <option value="@m.Cedula">@m.Nombre — @m.Cargo</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Orden.KilometrajeIngreso" class="form-label">Kilometraje de ingreso</label>
                            <input asp-for="Orden.KilometrajeIngreso" type="number" min="0" class="form-control" id="txtKm" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Orden.MotivoVisita" class="form-label">Motivo de la visita</label>
                            <input asp-for="Orden.MotivoVisita" class="form-control" maxlength="200" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Orden.DescripcionProblema" class="form-label">Descripción del problema</label>
                            <textarea asp-for="Orden.DescripcionProblema" class="form-control" maxlength="500" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Crear orden
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Carga en cascada de los vehículos del cliente elegido (fetch a una acción que devuelve JSON).
        (function () {
            var selCliente = document.getElementById("selCliente");
            var selVehiculo = document.getElementById("selVehiculo");
            var txtKm = document.getElementById("txtKm");
            var urlBase = "@Url.Action("VehiculosPorCliente")";

            selCliente.addEventListener("change", function () {
                var cedula = selCliente.value;
                selVehiculo.innerHTML = '<option value="">Cargando…</option>';
                selVehiculo.disabled = true;

                if (!cedula) {
                    selVehiculo.innerHTML = '<option value="">— Seleccione primero un cliente —</option>';
                    return;
                }

                fetch(urlBase + "?cedula=" + encodeURIComponent(cedula))
                    .then(function (r) { return r.json(); })
                    .then(function (vehiculos) {
                        if (!vehiculos || vehiculos.length === 0) {
                            selVehiculo.innerHTML = '<option value="">El cliente no tiene vehículos activos</option>';
                            selVehiculo.disabled = true;
                            return;
                        }
                        var html = '<option value="">— Seleccione un vehículo —</option>';
                        vehiculos.forEach(function (v) {
                            html += '<option value="' + v.placa + '" data-km="' + (v.kilometraje || "") + '">' + v.descripcion + '</option>';
                        });
                        selVehiculo.innerHTML = html;
                        selVehiculo.disabled = false;
                    })
                    .catch(function () {
                        selVehiculo.innerHTML = '<option value="">Error al cargar los vehículos</option>';
                        selVehiculo.disabled = true;
                    });
            });

            // Al elegir vehículo, sugiere su último kilometraje conocido si el campo está vacío.
            selVehiculo.addEventListener("change", function () {
                var opcion = selVehiculo.options[selVehiculo.selectedIndex];
                var km = opcion ? opcion.getAttribute("data-km") : "";
                if (km && !txtKm.value) {
                    txtKm.value = km;
                }
            });
        })();
    </script>
}

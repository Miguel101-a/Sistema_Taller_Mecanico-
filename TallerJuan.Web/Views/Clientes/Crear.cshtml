@model Cliente
@{
    ViewData["Title"] = "Nuevo cliente";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <h1 class="h3 mb-4"><i class="bi bi-person-plus me-2"></i>Nuevo cliente</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Cedula" class="form-label">Cédula <span class="text-danger">*</span></label>
                            <input asp-for="Cedula" class="form-control" maxlength="20" required autofocus />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" maxlength="100" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" maxlength="20" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Correo" class="form-label">Correo</label>
                            <input asp-for="Correo" type="email" class="form-control" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tipo" class="form-label">Tipo</label>
                            <select asp-for="Tipo" class="form-select">
                                <option value="">— Seleccione —</option>
                                <option value="particular">Particular</option>
                                <option value="empresarial">Empresarial</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" maxlength="200" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

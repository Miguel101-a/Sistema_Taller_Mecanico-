@model List<Empleado>
@{
    ViewData["Title"] = "Empleados";
    var sesion = Context.Session;
    bool puedeEditar = SesionWeb.TienePermiso(sesion, "EMPLEADOS_EDITAR");
    bool puedeEliminar = SesionWeb.TienePermiso(sesion, "EMPLEADOS_ELIMINAR");
    string cedulaActual = sesion.GetString(SesionWeb.ClaveCedula) ?? "";
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-person-badge me-2"></i>Empleados</h1>
        <p class="text-muted mb-0">Personal del taller y usuarios del sistema.</p>
    </div>
    @if (puedeEditar)
    {
        <a asp-action="Crear" class="btn btn-sgtmj-primario">
            <i class="bi bi-plus-lg me-1"></i>Nuevo empleado
        </a>
    }
</div>

<div class="card sgtmj-card shadow-sm border-0">
    <div class="sgtmj-tabla-herramientas">
        <input type="search" class="form-control sgtmj-buscador" placeholder="Buscar empleado…"
               data-tabla="tablaEmpleados" data-contador="contadorEmpleados" autocomplete="off" />
        <span class="sgtmj-contador" id="contadorEmpleados"></span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="tablaEmpleados">
            <thead class="table-light">
                <tr>
                    <th>Cédula</th>
                    <th>Nombre</th>
                    <th>Cargo</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    @if (puedeEditar || puedeEliminar)
                    {
                        <th class="text-end">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr data-sin-filtro>
                        <td colspan="7" class="text-center text-muted py-4">No hay empleados registrados.</td>
                    </tr>
                }
                @foreach (var e in Model)
                {
                    bool activo = e.Estado.Trim().ToUpperInvariant() == "ACTIVO";
                    bool esYoMismo = string.Equals(e.Cedula, cedulaActual, StringComparison.OrdinalIgnoreCase);
                    <tr class="@(activo ? "" : "text-muted opacity-75")">
                        <td class="fw-semibold">@e.Cedula</td>
                        <td>@e.Nombre</td>
                        <td>@e.Cargo</td>
                        <td>@e.Usuario</td>
                        <td>@e.RolNombre</td>
                        <td>
                            <span class="sgtmj-badge @(activo ? "sgtmj-estado-activo" : "sgtmj-estado-inactivo")">
                                @(activo ? "ACTIVO" : "INACTIVO")
                            </span>
                        </td>
                        @if (puedeEditar || puedeEliminar)
                        {
                            <td class="text-end">
                                @if (puedeEditar)
                                {
                                    <a asp-action="Editar" asp-route-id="@e.Cedula" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                }
                                @if (puedeEliminar && activo && !esYoMismo)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning js-confirmar"
                                            data-accion="@Url.Action("Eliminar")" data-campo="id" data-valor="@e.Cedula"
                                            data-mensaje="¿Está seguro de desactivar al empleado @e.Nombre?">
                                        <i class="bi bi-toggle-off me-1"></i>Desactivar
                                    </button>
                                }
                                else if (puedeEliminar && activo && esYoMismo)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled
                                            title="No puede desactivar su propio usuario.">
                                        <i class="bi bi-lock me-1"></i>Desactivar
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

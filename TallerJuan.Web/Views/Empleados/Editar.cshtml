@model Empleado
@{
    ViewData["Title"] = "Editar empleado";
    var roles = ViewBag.Roles as List<Rol> ?? new List<Rol>();
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <h1 class="h3 mb-4"><i class="bi bi-pencil-square me-2"></i>Editar empleado</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error</div>
        }

        <div class="alert alert-info py-2">
            <i class="bi bi-info-circle me-1"></i>El usuario y la contraseña no se modifican en esta pantalla.
        </div>

        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    @* La cédula es la PK: se muestra pero no se edita; se envía oculta. *@
                    <input type="hidden" asp-for="Cedula" />
                    <input type="hidden" asp-for="Usuario" />
                    <input type="hidden" asp-for="Estado" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Cédula</label>
                            <input class="form-control" value="@Model.Cedula" disabled readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" maxlength="100" required autofocus />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" maxlength="20" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Cargo" class="form-label">Cargo <span class="text-danger">*</span></label>
                            <input asp-for="Cargo" class="form-control" maxlength="30" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Especialidad" class="form-label">Especialidad</label>
                            <input asp-for="Especialidad" class="form-control" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Salario" class="form-label">Salario (Bs)</label>
                            <input asp-for="Salario" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" maxlength="200" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Usuario</label>
                            <input class="form-control" value="@Model.Usuario" disabled readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IdRol" class="form-label">Rol <span class="text-danger">*</span></label>
                            <select asp-for="IdRol" class="form-select" required>
                                <option value="">— Seleccione un rol —</option>
                                @foreach (var rol in roles)
                                {
                                    <option value="@rol.IdRol">@rol.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-sgtmj-primario">
                            <i class="bi bi-save me-1"></i>Guardar cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@model List<Factura>
@{
    ViewData["Title"] = "Facturación";
    var sesion = Context.Session;
    bool puedeEmitir = SesionWeb.TienePermiso(sesion, "FACTURAS_EMITIR");
    var cultura = new System.Globalization.CultureInfo("es-BO");
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-receipt me-2"></i>Facturación</h1>
        <p class="text-muted mb-0">Facturas emitidas, su estado y total con IVA 13% (relación 1:1 con la orden de trabajo).</p>
    </div>
    @if (puedeEmitir)
    {
        <a asp-action="Crear" class="btn btn-sgtmj-primario">
            <i class="bi bi-plus-lg me-1"></i>Nueva factura
        </a>
    }
</div>

<div class="card sgtmj-card shadow-sm border-0">
    <div class="sgtmj-tabla-herramientas">
        <input type="search" class="form-control sgtmj-buscador" placeholder="Buscar factura…"
               data-tabla="tablaFacturas" data-contador="contadorFacturas" autocomplete="off" />
        <span class="sgtmj-contador" id="contadorFacturas"></span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="tablaFacturas">
            <thead class="table-light">
                <tr>
                    <th>N°</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Vehículo</th>
                    <th>Orden</th>
                    <th class="text-end">Total</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr data-sin-filtro>
                        <td colspan="8" class="text-center text-muted py-4">No hay facturas registradas.</td>
                    </tr>
                }
                @foreach (var f in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@f.NumeroFactura</td>
                        <td>@f.FechaEmision.ToString("dd/MM/yyyy")</td>
                        <td>@f.ClienteNombre</td>
                        <td>@f.VehiculoDescripcion</td>
                        <td>
                            <a asp-controller="Ordenes" asp-action="Detalle" asp-route-id="@f.OrdenTrabajoNumeroOrden"
                               class="text-decoration-none">Nº @f.OrdenTrabajoNumeroOrden</a>
                        </td>
                        <td class="text-end fw-semibold">Bs @f.Total.ToString("N2", cultura)</td>
                        <td><partial name="_BadgeEstadoFactura" model="@f.Estado" /></td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-numeroFactura="@f.NumeroFactura" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Ver detalle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

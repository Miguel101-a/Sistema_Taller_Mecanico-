@model Factura
@{
    ViewData["Title"] = $"Factura N° {Model.NumeroFactura}";
    var sesion = Context.Session;
    bool puedeEmitir = SesionWeb.TienePermiso(sesion, "FACTURAS_EMITIR");
    bool puedeAnular = SesionWeb.TienePermiso(sesion, "FACTURAS_ANULAR");

    var detalles = ViewBag.Detalles as List<DetalleFactura> ?? new List<DetalleFactura>();
    var productos = ViewBag.Productos as List<Producto> ?? new List<Producto>();
    var cultura = new System.Globalization.CultureInfo("es-BO");

    string estado = Model.Estado.Trim().ToUpperInvariant();
    bool esBorrador = estado == "BORRADOR";
    bool esEmitida = estado == "EMITIDA";
    bool puedeTrabajar = puedeEmitir && esBorrador;   // editar líneas solo en BORRADOR
}

<div class="sgtmj-encabezado">
    <div>
        <h1><i class="bi bi-receipt me-2"></i>Factura N° @Model.NumeroFactura</h1>
        <p class="text-muted mb-0">
            Líneas de productos/servicios <span class="text-muted">(FACTURA ↔ PRODUCTO)</span> y totales con IVA 13%.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row g-4">
    @* ---------------- Columna izquierda: cabecera + líneas ---------------- *@
    <div class="col-lg-8">
        <div class="card sgtmj-card shadow-sm border-0 mb-4">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-info-circle me-1 text-muted"></i>Datos de la factura</span>
                <partial name="_BadgeEstadoFactura" model="@Model.Estado" />
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-4 col-md-3 text-muted">Cliente</dt>
                    <dd class="col-8 col-md-9">@Model.ClienteNombre <span class="text-muted">(@Model.ClienteCedula)</span></dd>

                    <dt class="col-4 col-md-3 text-muted">Vehículo</dt>
                    <dd class="col-8 col-md-9">@Model.VehiculoDescripcion</dd>

                    <dt class="col-4 col-md-3 text-muted">Orden</dt>
                    <dd class="col-8 col-md-9">
                        <a asp-controller="Ordenes" asp-action="Detalle" asp-route-id="@Model.OrdenTrabajoNumeroOrden"
                           class="text-decoration-none">Nº @Model.OrdenTrabajoNumeroOrden</a>
                    </dd>

                    <dt class="col-4 col-md-3 text-muted">Fecha emisión</dt>
                    <dd class="col-8 col-md-9">@(esBorrador ? "— (pendiente de emitir)" : Model.FechaEmision.ToString("dd/MM/yyyy HH:mm"))</dd>
                </dl>
            </div>
        </div>

        @* ---------------- Precargar repuestos de la orden (solo BORRADOR) ---------------- *@
        @if (puedeTrabajar)
        {
            <div class="card sgtmj-card shadow-sm border-0 mb-4">
                <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                        <span class="fw-semibold"><i class="bi bi-box-arrow-in-down me-1 text-muted"></i>Repuestos de la orden</span>
                        <div class="text-muted small">Precarga las salidas de inventario de la orden como líneas REPUESTO.</div>
                    </div>
                    <form asp-action="CargarRepuestos" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="numeroFactura" value="@Model.NumeroFactura" />
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-download me-1"></i>Cargar repuestos de la orden
                        </button>
                    </form>
                </div>
            </div>
        }

        @* ---------------- Tabla de líneas (detalle N:M) ---------------- *@
        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-list-ul me-1 text-muted"></i>Líneas (@detalles.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th>Descripción</th>
                            <th>Tipo</th>
                            <th class="text-end">Cant.</th>
                            <th class="text-end">P. unitario</th>
                            <th class="text-end">Subtotal</th>
                            @if (puedeTrabajar)
                            {
                                <th class="text-end">Acciones</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (detalles.Count == 0)
                        {
                            <tr>
                                <td colspan="@(puedeTrabajar ? 7 : 6)" class="text-center text-muted py-4">
                                    Aún no se han agregado líneas a esta factura.
                                </td>
                            </tr>
                        }
                        @foreach (var d in detalles)
                        {
                            bool esServicio = d.Tipo.Trim().ToUpperInvariant() == "SERVICIO";
                            <tr>
                                <td>
                                    <span class="fw-semibold">@d.ProductoNombre</span>
                                    <span class="text-muted small d-block">@d.ProductoCodigo</span>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(d.Descripcion) ? "—" : d.Descripcion)</td>
                                <td>
                                    <span class="sgtmj-badge @(esServicio ? "sgtmj-linea-servicio" : "sgtmj-linea-repuesto")">@d.Tipo</span>
                                </td>
                                <td class="text-end">@d.Cantidad</td>
                                <td class="text-end">Bs @d.PrecioUnitario.ToString("N2", cultura)</td>
                                <td class="text-end fw-semibold">Bs @d.Subtotal.ToString("N2", cultura)</td>
                                @if (puedeTrabajar)
                                {
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-danger js-confirmar"
                                                data-accion="@Url.Action("QuitarLinea", new { numeroFactura = Model.NumeroFactura })"
                                                data-campo="productoCodigo" data-valor="@d.ProductoCodigo"
                                                data-mensaje="¿Quitar la línea @d.ProductoNombre de la factura?">
                                            <i class="bi bi-trash me-1"></i>Quitar
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ---------------- Formulario "Agregar línea" (solo BORRADOR) ---------------- *@
        @if (puedeTrabajar)
        {
            <div class="card sgtmj-card shadow-sm border-0 mt-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-plus-circle me-1 text-muted"></i>Agregar línea
                </div>
                <div class="card-body">
                    <form asp-action="AgregarLinea" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="FacturaNumeroFactura" value="@Model.NumeroFactura" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Producto <span class="text-danger">*</span></label>
                                <select name="ProductoCodigo" class="form-select" id="selProducto" required>
                                    <option value="">— Seleccione un producto —</option>
                                    @foreach (var p in productos)
                                    {
                                        <option value="@p.Codigo" data-nombre="@p.Nombre"
                                                data-precio="@p.PrecioVenta.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                            @p.Nombre (@p.Codigo)
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Descripción</label>
                                <input name="Descripcion" id="txtDescripcion" class="form-control" maxlength="200" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label d-block">Tipo <span class="text-danger">*</span></label>
                                <div class="btn-group" role="group">
                                    <input type="radio" class="btn-check" name="Tipo" id="tipoRepuesto" value="REPUESTO" autocomplete="off" checked />
                                    <label class="btn btn-outline-primary" for="tipoRepuesto">REPUESTO</label>

                                    <input type="radio" class="btn-check" name="Tipo" id="tipoServicio" value="SERVICIO" autocomplete="off" />
                                    <label class="btn btn-outline-primary" for="tipoServicio">SERVICIO</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Cantidad <span class="text-danger">*</span></label>
                                <input name="Cantidad" type="number" min="1" value="1" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Precio unitario (Bs) <span class="text-danger">*</span></label>
                                <input name="PrecioUnitario" id="txtPrecio" type="number" step="0.01" min="0" value="0" class="form-control" required />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-sgtmj-primario mt-3">
                            <i class="bi bi-plus-lg me-1"></i>Agregar línea
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert sgtmj-stock-bajo border-0 mt-4 mb-0 d-flex align-items-center">
                <i class="bi bi-lock me-2"></i>La factura está @Model.Estado.ToUpperInvariant(); no se pueden modificar sus líneas.
            </div>
        }
    </div>

    @* ---------------- Columna derecha: totales + acciones ---------------- *@
    <div class="col-lg-4">
        <div class="card sgtmj-card shadow-sm border-0 mb-4">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-calculator me-1 text-muted"></i>Totales
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span>Bs @Model.Subtotal.ToString("N2", cultura)</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">IVA (13%)</span>
                    <span>Bs @Model.Iva.ToString("N2", cultura)</span>
                </div>
                <hr />
                <div class="sgtmj-cotiz-total">
                    <span>TOTAL</span>
                    <span>Bs @Model.Total.ToString("N2", cultura)</span>
                </div>
            </div>
        </div>

        @* ---------------- Emitir / Anular ---------------- *@
        <div class="card sgtmj-card shadow-sm border-0">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-check2-square me-1 text-muted"></i>Acciones
            </div>
            <div class="card-body">
                @if (esBorrador)
                {
                    @if (puedeEmitir)
                    {
                        <div class="d-grid">
                            <button type="button" class="btn btn-success js-confirmar"
                                    data-accion="@Url.Action("Emitir")"
                                    data-campo="numeroFactura" data-valor="@Model.NumeroFactura"
                                    data-mensaje="¿Emitir la factura N° @Model.NumeroFactura? Quedará bloqueada y no podrá editarse.">
                                <i class="bi bi-check-lg me-1"></i>Emitir factura
                            </button>
                        </div>
                        <p class="text-muted small mb-0 mt-2">La factura debe tener al menos una línea para poder emitirse.</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No tiene permisos para emitir facturas.</p>
                    }
                }
                else if (esEmitida)
                {
                    @if (puedeAnular)
                    {
                        <div class="d-grid">
                            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#modalAnular">
                                <i class="bi bi-x-octagon me-1"></i>Anular factura
                            </button>
                        </div>
                        <p class="text-muted small mb-0 mt-2">Al anular deberá indicar el motivo (queda en auditoría).</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0"><i class="bi bi-lock me-1"></i>Factura emitida. No tiene permisos para anularla.</p>
                    }
                }
                else
                {
                    <p class="text-muted mb-0"><i class="bi bi-lock me-1"></i>La factura está anulada; no admite más acciones.</p>
                }
            </div>
        </div>
    </div>
</div>

@* ---------------- Modal de anulación (motivo obligatorio, RF-34) ---------------- *@
@if (esEmitida && puedeAnular)
{
    <div class="modal fade" id="modalAnular" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Anular" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="numeroFactura" value="@Model.NumeroFactura" />
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-x-octagon text-danger me-2"></i>Anular factura N° @Model.NumeroFactura</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2">Esta acción no se puede deshacer. Indique el motivo de la anulación:</p>
                        <textarea name="motivo" class="form-control" rows="3" maxlength="180" required
                                  placeholder="Ej.: Error en los importes, solicitud del cliente…"></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>Confirmar anulación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Al elegir un producto, autocompleta la descripción (nombre) y el precio unitario
        // (PRECIO_VENTA) desde los atributos data-*; ambos quedan editables.
        (function () {
            var selProducto = document.getElementById("selProducto");
            if (!selProducto) return;
            var txtDescripcion = document.getElementById("txtDescripcion");
            var txtPrecio = document.getElementById("txtPrecio");

            selProducto.addEventListener("change", function () {
                var opcion = selProducto.options[selProducto.selectedIndex];
                if (!opcion || !opcion.value) return;
                txtDescripcion.value = opcion.getAttribute("data-nombre") || "";
                txtPrecio.value = opcion.getAttribute("data-precio") || "0";
            });
        })();
    </script>
}

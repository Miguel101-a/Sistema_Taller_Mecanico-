@model DashboardViewModel
@{
    ViewData["Title"] = "Inicio";
}

@* ----------------------- Saludo ----------------------- *@
<div class="sgtmj-card shadow-sm p-4 p-md-5 mb-4 d-flex align-items-center gap-4">
    <img src="~/img/logo.png" alt="Logo Taller Mecánico JUAN" class="sgtmj-inicio-logo d-none d-sm-block" />
    <div>
        <h1 class="h3 fw-semibold mb-1">Bienvenido, @Model.Nombre</h1>
        <p class="text-muted mb-0">
            Sistema de Gestión del Taller Mecánico Automotriz JUAN
            <span class="text-muted">— Rol: <span class="fw-semibold">@Model.Rol</span></span>
        </p>
    </div>
</div>

@if (Model.HayTarjetas)
{
    <h2 class="h5 fw-semibold mb-3 text-muted"><i class="bi bi-grid-1x2 me-2"></i>Resumen del taller</h2>
    <div class="row g-4">
        @if (Model.VerClientes)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-controller="Clientes" asp-action="Index" class="text-decoration-none">
                    <div class="card sgtmj-card sgtmj-reporte-card shadow-sm border-0 h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="sgtmj-reporte-icono"><i class="bi bi-people"></i></div>
                            <div>
                                <div class="sgtmj-dash-numero">@Model.ClientesActivos</div>
                                <div class="text-muted small">Clientes activos</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
        @if (Model.VerOrdenes)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-controller="Ordenes" asp-action="Index" class="text-decoration-none">
                    <div class="card sgtmj-card sgtmj-reporte-card shadow-sm border-0 h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="sgtmj-reporte-icono"><i class="bi bi-wrench-adjustable"></i></div>
                            <div>
                                <div class="sgtmj-dash-numero">@Model.OrdenesEnProceso</div>
                                <div class="text-muted small">Órdenes en proceso</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
        @if (Model.VerInventario)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-controller="Inventario" asp-action="Index" class="text-decoration-none">
                    <div class="card sgtmj-card sgtmj-reporte-card shadow-sm border-0 h-100 @(Model.ProductosBajoStock > 0 ? "sgtmj-dash-alerta" : "")">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="sgtmj-reporte-icono @(Model.ProductosBajoStock > 0 ? "sgtmj-dash-icono-alerta" : "")">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <div>
                                <div class="sgtmj-dash-numero">@Model.ProductosBajoStock</div>
                                <div class="text-muted small">Productos bajo stock mínimo</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
        @if (Model.VerCotizaciones)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-controller="Cotizaciones" asp-action="Index" class="text-decoration-none">
                    <div class="card sgtmj-card sgtmj-reporte-card shadow-sm border-0 h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="sgtmj-reporte-icono"><i class="bi bi-file-earmark-text"></i></div>
                            <div>
                                <div class="sgtmj-dash-numero">@Model.CotizacionesPendientes</div>
                                <div class="text-muted small">Cotizaciones pendientes</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
        @if (Model.VerFacturas)
        {
            <div class="col-sm-6 col-xl-4">
                <a asp-controller="Facturacion" asp-action="Index" class="text-decoration-none">
                    <div class="card sgtmj-card sgtmj-reporte-card shadow-sm border-0 h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <div class="sgtmj-reporte-icono"><i class="bi bi-receipt"></i></div>
                            <div>
                                <div class="sgtmj-dash-numero">@Model.FacturasDelMes</div>
                                <div class="text-muted small">Facturas emitidas del mes</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="sgtmj-card shadow-sm p-4 text-center text-muted">
        <p class="mb-0">No tiene módulos asignados. Contacte al administrador para obtener permisos.</p>
    </div>
}
